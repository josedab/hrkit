{
  "$schema": "https://typedoc.org/schema.json",
  "name": "@hrkit",
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/polar/src/index.ts",
    "packages/web/src/index.ts",
    "packages/react-native/src/index.ts",
    "packages/server/src/index.ts",
    "packages/widgets/src/index.ts",
    "packages/ai/src/index.ts",
    "packages/ant/src/index.ts",
    "packages/bundle/src/index.ts",
    "packages/capacitor/src/index.ts",
    "packages/capacitor-native/src/index.ts",
    "packages/cli/src/index.ts",
    "packages/coach/src/index.ts",
    "packages/edge/src/index.ts",
    "packages/integrations/src/index.ts",
    "packages/ml/src/index.ts",
    "packages/otel/src/index.ts",
    "packages/readiness/src/index.ts",
    "packages/sync/src/index.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "website/docs/api",
  "entryFileName": "index",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "hideGenerator": true,
  "githubPages": false,
  "exclude": ["**/__tests__/**", "**/dist/**", "**/*.test.ts"],
  "tsconfig": "tsconfig.typedoc.json",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": true,
  "useCodeBlocks": true,
  "expandObjects": true,
  "expandParameters": true,
  "indexFormat": "table",
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table"
}
