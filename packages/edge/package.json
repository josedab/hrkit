{
  "name": "@hrkit/edge",
  "version": "0.1.0",
  "description": "Runtime-portable HR ingestion for Cloudflare Workers / Deno / Bun edge environments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/edge"
  },
  "keywords": [
    "edge",
    "cloudflare-workers",
    "deno",
    "bun",
    "ingestion",
    "heart-rate",
    "hrkit"
  ],
  "author": "@hrkit contributors",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/edge",
  "engines": {
    "node": ">=18"
  }
}
