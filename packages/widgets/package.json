{
  "name": "@hrkit/widgets",
  "version": "0.1.0",
  "description": "Live dashboard Web Components for @hrkit — heart rate gauge, zone bar, HR chart",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "files": ["dist"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/widgets"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "heart-rate",
    "web-components",
    "dashboard",
    "widgets",
    "hrkit"
  ],
  "author": "@hrkit contributors",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/widgets"
}
