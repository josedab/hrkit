{
  "name": "@hrkit/bundle",
  "version": "0.1.0",
  "description": "Sign & verify @hrkit conformance bundles using Web Crypto ECDSA P-256.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/bundle"
  },
  "keywords": [
    "hrkit",
    "conformance",
    "signing",
    "ed25519",
    "ecdsa"
  ],
  "author": "@hrkit contributors",
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://hrkit.dev"
}
