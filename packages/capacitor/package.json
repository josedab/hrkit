{
  "name": "@hrkit/capacitor",
  "version": "0.1.0",
  "description": "Capacitor BLE adapter for @hrkit (iOS + Android via @capacitor-community/bluetooth-le)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "peerDependencies": {
    "@capacitor-community/bluetooth-le": "^7.0.0 || ^6.0.0 || ^4.0.0",
    "@capacitor/core": "^7.0.0 || ^6.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor-community/bluetooth-le": {
      "optional": false
    },
    "@capacitor/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/capacitor"
  },
  "keywords": [
    "capacitor",
    "ble",
    "ios",
    "android",
    "heart-rate",
    "hrkit"
  ],
  "author": "@hrkit contributors",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/capacitor",
  "engines": {
    "node": ">=18"
  }
}
