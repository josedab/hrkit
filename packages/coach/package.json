{
  "name": "@hrkit/coach",
  "version": "0.1.0",
  "description": "AI coaching layer for @hrkit \u2014 deterministic rule-engine summaries + LLM adapters (OpenAI/Anthropic/Ollama)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/coach"
  },
  "keywords": [
