    "coach",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "heart-rate",
    "hrkit"
  ],
  "author": "@hrkit contributors",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/coach",
  "engines": {
    "node": ">=18"
