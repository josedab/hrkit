{
  "name": "@hrkit/integrations",
  "version": "0.1.0",
  "description": "Third-party integrations for @hrkit \u2014 FIT export and Strava/Garmin/TrainingPeaks/Intervals.icu uploaders",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fit": {
      "types": "./dist/fit.d.ts",
      "import": "./dist/fit.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/integrations"
  },
  "keywords": [
    "fit",
    "strava",
    "garmin",
    "trainingpeaks",
    "intervals.icu",
    "heart-rate",
    "hrkit"
  ],
  "author": "@hrkit contributors",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/integrations",
  "engines": {
    "node": ">=18"
  }
}
