{
  "name": "@hrkit/otel",
  "version": "0.1.0",
  "description": "OpenTelemetry-compatible instrumentation hooks for @hrkit transports and sessions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "grafana"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "keywords": [
    "hrkit",
    "opentelemetry",
    "otel",
    "observability",
    "metrics"
  ],
  "author": "@hrkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/otel"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://hrkit.dev"
}
