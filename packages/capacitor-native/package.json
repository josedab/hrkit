{
  "name": "@hrkit/capacitor-native",
  "version": "0.1.0",
  "description": "Native Capacitor plugin for @hrkit \u2014 direct CoreBluetooth (iOS) and android.bluetooth (Android) bindings, no community deps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "ios",
    "android",
    "HrkitCapacitorNative.podspec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0 || ^6.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "license": "MIT",
  "keywords": [
    "capacitor",
    "plugin",
    "ble",
    "bluetooth",
    "ios",
    "android",
    "heart-rate",
    "ecg",
    "hrkit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/capacitor-native"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/capacitor-native",
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
