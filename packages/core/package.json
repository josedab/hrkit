{
  "name": "@hrkit/core",
  "version": "0.2.0",
  "description": "Zero-dependency TypeScript library for BLE heart rate sensor data processing",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": ["heart-rate", "hrv", "ble", "bluetooth", "trimp", "fitness", "sdk", "typescript"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./profiles": {
      "types": "./dist/profiles/index.d.ts",
      "import": "./dist/profiles/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0"
  }
}