{
  "name": "@hrkit/react-native",
  "version": "0.1.0",
  "description": "React Native BLE adapter for @hrkit using react-native-ble-plx",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "peerDependencies": {
    "react-native-ble-plx": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "react-native-ble-plx": "^3.0.0"
  },
  "keywords": [
    "ble",
    "bluetooth",
    "heart-rate",
    "react-native",
    "hrv"
  ],
  "author": "@hrkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/react-native",
  "license": "MIT"
}
