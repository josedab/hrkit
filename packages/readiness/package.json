{
  "name": "@hrkit/readiness",
  "version": "0.1.0",
  "description": "Readiness scoring for @hrkit \u2014 adaptive HRV baseline + multi-factor recovery model.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "keywords": [
    "hrkit",
    "readiness",
    "hrv",
    "training-load",
    "recovery"
  ],
  "author": "@hrkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/readiness"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://hrkit.dev"
}
