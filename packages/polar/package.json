{
  "name": "@hrkit/polar",
  "version": "0.1.0",
  "description": "Polar PMD protocol utilities for @hrkit \u2014 ECG and accelerometer data streaming",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "ble",
    "bluetooth",
    "heart-rate",
    "polar",
    "ecg",
    "hrv"
  ],
  "author": "@hrkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/polar"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/polar",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
