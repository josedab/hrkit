{
  "name": "@hrkit/web",
  "version": "0.1.0",
  "description": "Web Bluetooth API adapter for @hrkit heart rate monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json"
  },
  "dependencies": {
    "@hrkit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/web-bluetooth": "^0.0.21",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "ble",
    "bluetooth",
    "heart-rate",
    "web-bluetooth",
    "hrv"
  ],
  "author": "@hrkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/josedab/hrkit.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/josedab/hrkit/issues"
  },
  "homepage": "https://github.com/josedab/hrkit/tree/main/packages/web",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
